Important scanner contract:\
\
type ScannerMode =\
  | \{ scope: "globalInventory" \}\
  | \{ scope: "load"; loadId: string \}\
  | \{ scope: "putawayTask"; taskId: string \}\
  | \{ scope: "shipment"; shipmentId: string \}\
